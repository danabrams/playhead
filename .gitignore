# Claude Code worktrees
.claude/worktrees/
.worktrees/

# Dev-only analysis exports from the app
*.xcappdata/

# Dated captures we keep locally for repeat analysis (xcappdata bundles moved here)
.captures/

# Auto-generated session summaries (ntm)
.ntm/summaries/

# ntm machine-local provider state — not portable across machines
.ntm/rate_limits.json

# ntm per-session agent logs (am-/cm- panes)
.ntm/logs/

# Claude Code session lockfile — runtime state, not source
.claude/scheduled_tasks.lock

# Disk-cleanup script log — append-only runtime state
.logs/

# Wizard round archive — cached locally, never committed
.wizard-archive/

# Dueling-idea-wizards skill artifacts at repo root (reactions,
# blindspots, ideas, scores, dueling reports). Generated locally per
# session; never committed. Without these patterns a `git add -A`
# would silently include them.
#
# Cycle-23 L-1: anchor with leading `/` so the patterns ONLY match
# at the repo root. Without the anchor, `WIZARD_*.md` would also
# match e.g. `Playhead/Docs/WIZARD_FOO.md`, which could silently
# hide a deliberately-named documentation file deep in the tree.
/WIZARD_*.md
/DUELING_*_REPORT.md

# narl eval harness output (reports, trend log) — regenerated per run
.eval-out/

# playhead-l2f labeled corpus: JSON annotations + README are committed,
# but the referenced audio files (~2-3 GB total when full) are kept
# out of the repo. They live alongside the annotations on the
# annotator's machine and are verified via `audio_fingerprint`.
TestFixtures/Corpus/Audio/*
!TestFixtures/Corpus/Audio/.gitkeep
