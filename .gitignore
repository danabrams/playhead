# Swift Package Manager
.build/
Packages/
Package.resolved

# macOS
.DS_Store

# Claude Code worktrees
.claude/worktrees/
.worktrees/

# Dev-only analysis exports from the app
*.xcappdata/

# Dated captures we keep locally for repeat analysis (xcappdata bundles moved here)
.captures/

# Auto-generated session summaries (ntm)
.ntm/summaries/

# ntm machine-local provider state — not portable across machines
.ntm/rate_limits.json

# ntm per-session agent logs (am-/cm- panes)
.ntm/logs/

# Claude Code session lockfile — runtime state, not source
.claude/scheduled_tasks.lock

# Disk-cleanup script log — append-only runtime state
.logs/

# Wizard round archive — cached locally, never committed
.wizard-archive/

# narl eval harness output (reports, trend log) — regenerated per run
.eval-out/
