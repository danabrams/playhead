        <outline type="rss" text="Has feed" xmlUrl="https://example.com/has.rss"/>
        <outline type="rss" text="Folder no xmlUrl"/>
        <outline type="link" text="Bookmark" url="https://example.com/page"/>
    </body>
</opml>
